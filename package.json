{
  "name": "oblac-tests",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "typecheck": "tsc --noEmit",
    "generate:api": "swagger-typescript-api generate -p https://synapticon.github.io/oblac/motion-master-api/swagger.yml -o src -n mm-api.ts",
    "format": "biome format --write .",
    "check": "biome check --write ."
  },
  "dependencies": {
    "motion-master-client": "^0.0.390",
    "rxjs": "^7.8.2",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/semver": "^7.7.1",
    "@types/ws": "^8.18.1",
    "@vitest/ui": "^2.0.0",
    "swagger-typescript-api": "^13.7.2",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
