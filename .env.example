# Motion Master container version (overrides docker-compose default)
MM_VERSION=v5.5.0

# Motion Master API container version (overrides docker-compose default)
MM_API_VERSION=v0.0.396

# Network interface MAC address for EtherCAT (required)
MM_MAC=

# EtherCAT driver: soem | rtsoem
MM_DRV=soem

# WebSockets ports
MM_REQ_RES_PORT=63524
MM_PUB_SUB_PORT=63525

# HTTP API port (base URL will be http://localhost:{MM_API_PORT}/api)
MM_API_PORT=63526

# Comma-separated IP allowlist (leave empty for any)
MM_IPS=

# PDO mode: monitor | cyclic
MM_PDO_MODE=monitor

# PSU HTTP controller base URL (P1535 ESP32)
PSU_URL=http://192.168.212.103
